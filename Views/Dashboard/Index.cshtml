@model ShopTracker.ViewModels.DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
}

<h1 class="mb-4">Shop Dashboard</h1>

<div class="row g-3">

    <div class="col-md-3">
        <div class="card kard kard-primary text-center border-primary">
            <div class="card-body">
                            <i class="bi bi-box text-light" style="font-size: 2rem;"></i>
                <h5 class="card-title">Week Revenue</h5>
                <p class="card-text">@Model.WeeklyRevenue.ToString("C")</p>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card kard kard-success text-center border-primary">
            <div class="card-body">
                                        <i class="bi bi-box text-light" style="font-size: 2rem;"></i>
                <h5 class="card-title">Week Profit</h5>
                <p class="card-text">@Model.WeeklyProfit.ToString("C")</p>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card kard kard-primary text-center border-primary">
            <div class="card-body">
                                        <i class="bi bi-box text-light" style="font-size: 2rem;"></i>
                <h5 class="card-title">Week Items Sold</h5>
                <p class="card-text">@Model.WeeklyItemsSold</p>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card kard kard-success text-center border-primary">
            <div class="card-body">
                                        <i class="bi bi-box text-light" style="font-size: 2rem;"></i>
                <h5 class="card-title">Products in Stock</h5>
                <p class="card-text">@Model.TotalProductsInStock</p>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card kard kard-success text-center border-primary">
            <div class="card-body">
                                        <i class="bi bi-box text-light" style="font-size: 2rem;"></i>
                <h5 class="card-title">Daily Revenue</h5>
                <p class="card-text">@Model.DailyRevenue</p>
            </div>
        </div>
    </div>
    
    <div class="col-md-3">
        <div class="card kard kard-success text-center border-primary">
            <div class="card-body">
                                        <i class="bi bi-box text-light" style="font-size: 2rem;"></i>
                <h5 class="card-title">Daily Profit</h5>
                <p class="card-text">@Model.DailyProfit</p>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card kard kard-success text-center border-primary">
            <div class="card-body">
                                        <i class="bi bi-box text-light" style="font-size: 2rem;"></i>
                <h5 class="card-title">Daily Items Sold</h5>
                <p class="card-text">@Model.DailyItemsSold</p>
            </div>
        </div>
    </div>

</div>

@if (Model.SoldOutProducts.Any())
{
    <div class="mt-4">
        <h4>Sold Out Products</h4>
        <ul class="list-group">
            @foreach (var product in Model.SoldOutProducts)
            {
                <li class="list-group-item list-group-item-success">@product</li>
            }
        </ul>
    </div>
}

<div class="text-center mt-5 mb-3">
        <h3>Quick Actions</h3>
    </div>
    <div class="d-flex justify-content-center gap-3 mb-5">
        <a asp-controller="Product" asp-action="Create" class="btn btn-primary">
            <i class="bi bi-box"></i> Add New Product
        </a>
        <a asp-controller="Sales" asp-action="Create" class="btn btn-primary">
            <i class="bi bi-box"></i> Sell New Product
        </a>
        <a asp-controller="Sales" asp-action="History" class="btn btn-primary">
            <i class="bi bi-box"></i> View Sales History
        </a>
    </div>