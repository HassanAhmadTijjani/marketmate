@model ShopTracker.Models.Product
@{
    ViewData["Title"] = "ShopTracker";
}


<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <h2>Add new product</h2>
            <hr>
            <form asp-action="Create" method="post">
                <div asp-validation-summary="All" class="text-danger mb-3"></div>
                <div class="mb-3">
                    <label asp-for="Name" class="form-label"></label>
                    <input asp-for="Name" class="form-control" placeholder="Enter product name" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="CostPrice" class="form-label"></label>
                    <input asp-for="CostPrice" class="form-control" placeholder="Enter product cost price" />
                    <span asp-validation-for="CostPrice" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="SellingPrice" class="form-label"></label>
                    <input asp-for="SellingPrice" class="form-control" placeholder="Enter product selling price" />
                    <span asp-validation-for="SellingPrice" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="QuantityInStock" class="form-label"></label>
                    <input asp-for="QuantityInStock" class="form-control" placeholder="Enter product quantity in stock" />
                    <span asp-validation-for="QuantityInStock" class="text-danger"></span>
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">Save Product</button>
                    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>


@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}