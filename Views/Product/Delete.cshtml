@model ShopTracker.Models.Product
@{
    ViewData["Title"] = "ShopTracker";
}


<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <h2>Delete product</h2>
            <hr>
            <h3>Are you sure you want to delete this product?</h3>
            <form asp-action="Delete" asp-route-id="@Model.ProductId" method="post">
                <div asp-validation-summary="All" class="text-danger mb-3"></div>
                <div class="mb-3">
                    <label asp-for="Name" class="form-label"></label>
                    <input  asp-for="Name" disabled class="form-control" placeholder="Enter product name" />
                </div>
                <div class="mb-3">
                    <label asp-for="CostPrice" class="form-label"></label>
                    <input asp-for="CostPrice" disabled class="form-control" placeholder="Enter product cost price" />
                </div>
                <div class="mb-3">
                    <label asp-for="SellingPrice" class="form-label"></label>
                    <input asp-for="SellingPrice" disabled class="form-control" placeholder="Enter product selling price" />
                </div>
                <div class="mb-3">
                    <label asp-for="QuantityInStock" class="form-label"></label>
                    <input asp-for="QuantityInStock" disabled class="form-control" placeholder="Enter product quantity in stock" />
                </div>
                <div class="d-flex gap-2">
                    <input type="submit" value="Delete" class="btn btn-danger" />
                    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>


@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}