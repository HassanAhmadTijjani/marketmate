@model ShopTracker.Models.Product
@{
    ViewData["Title"] = "ShopTracker";
}



<h1 class="px-5 py-3">Product Detail</h1>

<div class="row">
    <hr />
    <div class="col-md-8">
        <dl class="row px-5">
            <dt class="col-6 col-sm-3">Name</dt>
            <dd class="col-6 col-sm-9">@Model.Name</dd>

            <dt class="col-6 col-sm-3">Cost Price</dt>
            <dd class="col-6 col-sm-9">@Model.CostPrice.ToString("C")</dd>

            <dt class="col-6 col-sm-3">Selling Price</dt>
            <dd class="col-6 col-sm-9">@Model.SellingPrice.ToString("C")</dd>
            <dt class="col-6 col-sm-3"> Quantity in Stock</dt>
            <dd class="col-6 col-sm-9">@Model.QuantityInStock</dd>
            <dt class="col-6 col-sm-3"> Expected Profit</dt>
            <dd class="col-6 col-sm-9">@Model.Profit.ToString("C")</dd>

            <dt class="col-6 col-sm-3">Date Added</dt>
            <dd class="col-6 col-sm-9">@(Model.DateCreated.ToShortDateString())</dd>
        </dl>
    </div>
    <div class="px-5 py-3">
        <a asp-action="Edit" asp-route-id="@Model.ProductId" class="btn btn-warning"> <i
                class="bi bi-pencil-square"></i>
            Edit</a>
        <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-arrow-left"></i>Back to List</a>
    </div>