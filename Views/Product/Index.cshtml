@model IEnumerable<ShopTracker.Models.Product>

@{
    ViewData["Title"] = "ShopTracker";
}


<div
    class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center p-3 mt-4 mb-4">
    <div>
        <h1 class="mb-3 mb-md-0">Products</h1>
    </div>
    <div>
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Add New Product
        </a>
    </div>
</div>


@* SearchBar *@
<form asp-action="Index" method="get" class="mb-3">
    <div class="row">
        <div class="col-md-6">
            <div class="input-group">
                <input type="text" name="searchString" value="@ViewData["CurrentFilter"]" class="form-control"
                    placeholder="Search products..." />
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-search"></i> Search
                </button>
            </div>
        </div>
    </div>
</form>
@if (!string.IsNullOrEmpty(ViewData["CurrentFilter"]?.ToString()))
{
    <div class="mb-3">
        <span class="text-muted">
            Search result for: <strong>@ViewData["CurrentFilter"]</strong>
        </span>
        <a asp-action="Index" class="btn btn-sm btn-outline-secondary ms-2">
            Clear Search
        </a>
    </div>
}


<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <td>Name</td>
                <td>Cost Price</td>
                <td>Selling Price</td>
                <td>Quantity</td>
                @* <td>Date Created</td> *@
            </tr>
        </thead>
        <tbody>
    @if (Model != null && Model.Any())
    {
        foreach (var product in Model)
        {
            <tr>
                <td>@product.Name</td>
                <td>@product.CostPrice.ToString("C")</td>
                <td>@product.SellingPrice.ToString("C")</td>
                <td>@product.QuantityInStock</td>
                @* <td>@product.DateCreated.ToShortDateString()</td> *@
                <td>
                    <div class="d-flex flex-column flex-md-row gap-2">
                        <a asp-action="Edit" asp-route-id="@product.ProductId" class="btn btn-sm btn-warning">
                            <i class="bi bi-pencil-square"></i> Edit
                        </a>

                        <a asp-action="Detail" asp-route-id="@product.ProductId" class="btn btn-sm btn-info">
                            <i class="bi bi-info-circle"></i> Details
                        </a>

                        <a asp-action="Delete" asp-route-id="@product.ProductId" class="btn btn-sm btn-danger">
                            <i class="bi bi-trash"></i> Delete
                        </a>
                    </div>
                </td>
            </tr>
        }
    }
    else
    {
        <tr>
            <td colspan="6" class="text-center py-5 text-muted">
                <i class="bi bi-inbox" style="font-size: 3rem;"></i>
                <p class="mt-3">No Products found. Add Products!</p>
            </td>
        </tr>
    }
</tbody>
    </table>
</div>