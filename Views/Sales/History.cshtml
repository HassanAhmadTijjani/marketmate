@* @model ShopTracker.Controllers.SalesController *@

@model IEnumerable<ShopTracker.Models.SaleItem>
@{
    ViewData["Title"] = "ShopTracker";
}

<div
    class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center p-3 mt-4 mb-4">
    <div>
        <h1 class="mb-3 mb-md-0">Sales Tracker</h1>
    </div>
    <div>
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Add New Sale
        </a>
    </div>
</div>

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <td>Name</td>
                @* <td>Cost Price</td> *@
                <td>Selling Price</td>
                <td>Quantity</td>
                <td>Date Created</td>
                <td>Date Sold</td>
            </tr>
        </thead>
        <tbody>
        @* <tr>
            <td>@product.Product.Name</td>
                        <td>@product.PriceAtSale.ToString("C")</td>
                        <td>@product.Quantity</td>
                        <td>@product.Sale.DateCreated</td>
        </tr> *@
            @if (Model != null && Model.Any())
            {
                @foreach (var product in Model)
                {
                    <tr>
                        <td>@product.Product.Name</td>
                        <td>@product.PriceAtSale.ToString("C")</td>
                        <td>@product.Quantity</td>
                        <td>@product.Sale.DateCreated</td>
                        <td>@product.Sale.DateSold</td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="6" class="text-center py-5 text-muted">
                        <i class="bi bi-inbox" style="font-size: 3rem;"></i>
                        <p class="mt-3">No Products found. Add Products!</p>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>